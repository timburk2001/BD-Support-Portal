# Supabase — find these in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — server-only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — for transactional email (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=support@yourdomain.com

# Anthropic — for AI fix recommendations
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# Override model; defaults to claude-haiku-4-5-20251001 (fast + cheap)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Public app URL — used for OAuth redirects and email links.
# Production: https://www.burkdigital.support  ·  Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://www.burkdigital.support
